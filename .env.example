# Discord
DISCORD_TOKEN=discord_bot_token
DISCORD_CLIENT_ID=discord_client_id
DISCORD_GUILD_ID=discord_server_id

# Riot API
RIOT_API_KEY=key-here
RIOT_PLATFORM=EUW1
RIOT_REGION=europe

# Storage
STORAGE_PATH=data/storage.json

# Turnier commands
TOURNAMENT_ROLE_ID=role_id_here

# Fearless — Team voice channels
TEAM_VOICE_CATEGORY_ID=category_id_here

# Fearless — Captain role for tournament code buttons
CAPTAIN_ROLE_ID=captain_role_here

# Fearless — Channel for /startmatch embeds
MATCHES_CHANNEL_ID=matches_channel_id

# Logs — Admin command audit trail and errors (optional)
LOG_CHANNEL_ID=log_channel_id

# Results — Rich match stats posted after every scan (optional)
RESULTS_CHANNEL_ID=results_channel_id

# Fearless — Auto-scan (polls match history automatically)
AUTOSCAN_ENABLED=false
AUTOSCAN_INTERVAL_SEC=120
AUTOSCAN_MIN_PLAYERS_PER_TEAM=5
AUTOSCAN_CHANNEL_ID=results_channel_id

# Riot tournament stub (required for /startmatch tournament codes)
TOURNAMENT_CALLBACK_URL=https://example.com/riot-callback

# Discord nickname format: {gameName}, {tagLine}, {riotId}
NICKNAME_FORMAT={gameName}